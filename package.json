{
  "name": "redis-agent-mcp",
  "version": "1.0.0",
  "description": "MCP server for AI agent team communication via Redis pub/sub",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "redis-agent-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "watch": "tsc --watch",
    "package:win": "pkg . --targets node18-win-x64 --compress Brotli --output mcp-server-windows.exe",
    "package:linux": "pkg . --targets node18-linux-x64 --compress Brotli --output mcp-server-linux",
    "package:macos": "pkg . --targets node18-macos-x64 --compress Brotli --output mcp-server-macos",
    "package:all": "npm run package:win && npm run package:linux && npm run package:macos"
  },
  "keywords": [
    "mcp",
    "redis",
    "ai-agents",
    "pub-sub",
    "team-communication"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "ioredis": "^5.3.2",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "pkg": "^5.8.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
